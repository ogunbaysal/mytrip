# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/logoloco"
DATABASE_SSL=false

# API Configuration
PORT=3002
BETTER_AUTH_SECRET="change-me-very-secret-key"
BETTER_AUTH_URL="http://localhost:3002"

# CORS Configuration
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3002"
COOKIE_DOMAIN=".yourdomain.com"

# Database Pool Configuration
PGPOOL_MAX=50
PGPOOL_IDLE_MS=30000
PGPOOL_CONN_TIMEOUT_MS=5000

# Iyzico Subscription Configuration
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_MERCHANT_ID=
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"
IYZICO_LOCALE="tr"
IYZICO_SUBSCRIPTION_INITIAL_STATUS="ACTIVE"
# JSON map: {"internal_plan_id":"iyzico_pricing_plan_reference_code"}
IYZICO_PLAN_REFERENCE_MAP='{"starter":"iyzico_pricing_plan_reference_code"}'
IYZICO_WEBHOOK_ALLOW_UNSIGNED="false"
IYZICO_DEFAULT_IDENTITY_NUMBER="11111111111"
IYZICO_DEFAULT_GSM_NUMBER="+905555555555"
IYZICO_DEFAULT_COUNTRY="Turkey"
IYZICO_DEFAULT_CITY="Istanbul"
IYZICO_DEFAULT_DISTRICT="Kadikoy"
IYZICO_DEFAULT_ZIP_CODE="34742"
IYZICO_DEFAULT_ADDRESS="Nidakule Goztepe, Merdivenkoy Mah. Bora Sok. No:1"
